# 이 파일을 ~/.model-stats/.env 로 복사 후 값 채우기 (repo에 실키 커밋 금지).
# 전부 선택사항 — 아무것도 안 해도 내장 기본값으로 동작(zero-config).

# Supabase 덮어쓰기(자기 프로젝트로 기록하려면). 미설정 시 내장 기본 프로젝트 사용.
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_KEY=YOUR-ANON-KEY

# 분류: 기본적으로 내장 CF Worker(DeepSeek 대행)가 category/난이도/도메인/성패 판정.
# 자기 Worker로 바꾸려면 아래 지정. Worker 없거나 실패 시 로컬 규칙으로 자동 폴백.
# MODEL_STATS_WORKER_URL=https://your-worker.workers.dev
# MODEL_STATS_WORKER_TOKEN=your-shared-token
